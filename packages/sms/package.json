{
  "name": "@dudousxd/nestjs-notifications-sms",
  "version": "0.6.0",
  "description": "SMS channel for nestjs-notifications — send SMS notifications via a pluggable transport (Twilio built-in)",
  "license": "MIT",
  "author": "Davide Carvalho",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/nestjs-notifications.git",
    "directory": "packages/sms"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-notifications-core": ">=0.1.0 <1.0.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "twilio": "^5.0.0",
    "@vonage/server-sdk": ">=3",
    "@aws-sdk/client-sns": ">=3"
  },
  "peerDependenciesMeta": {
    "twilio": {
      "optional": true
    },
    "@vonage/server-sdk": {
      "optional": true
    },
    "@aws-sdk/client-sns": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dudousxd/nestjs-notifications-core": "workspace:^",
    "@nestjs/common": "11.1.26",
    "twilio": "5.13.1",
    "@vonage/server-sdk": "3.27.0",
    "@aws-sdk/client-sns": "3.1066.0",
    "reflect-metadata": "0.2.2",
    "typescript": "5.9.3"
  },
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  }
}
