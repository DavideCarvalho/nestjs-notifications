{
  "name": "@dudousxd/nestjs-notifications-database-typeorm",
  "version": "0.7.0",
  "description": "TypeORM adapter for the nestjs-notifications database channel",
  "license": "MIT",
  "author": "Davide Carvalho",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/nestjs-notifications.git",
    "directory": "packages/database-typeorm"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-notifications-database": ">=0.1.0 <1.0.0",
    "@dudousxd/nestjs-notifications-preferences": ">=0.1.0 <1.0.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/typeorm": "^10.0.0 || ^11.0.0",
    "typeorm": "^0.3.0"
  },
  "peerDependenciesMeta": {
    "@dudousxd/nestjs-notifications-preferences": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dudousxd/nestjs-notifications-core": "workspace:^",
    "@dudousxd/nestjs-notifications-database": "workspace:^",
    "@dudousxd/nestjs-notifications-preferences": "workspace:^",
    "@nestjs/common": "11.1.26",
    "@nestjs/typeorm": "11.0.1",
    "@testcontainers/mysql": "10.18.0",
    "@testcontainers/postgresql": "10.18.0",
    "mysql2": "3.11.5",
    "pg": "8.13.1",
    "reflect-metadata": "0.2.2",
    "typeorm": "0.3.30",
    "typescript": "5.9.3",
    "sqlite3": "5.1.7"
  },
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  }
}
