{
  "name": "@dudousxd/nestjs-notifications-client",
  "version": "0.8.0",
  "description": "Framework-neutral headless SDK for nestjs-notifications — fetch client + SSE subscribe + TanStack Query factories",
  "license": "MIT",
  "author": "Davide Carvalho",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/nestjs-notifications.git",
    "directory": "packages/client"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./tanstack": {
      "import": {
        "types": "./dist/tanstack.d.ts",
        "default": "./dist/tanstack.js"
      },
      "require": {
        "types": "./dist/tanstack.d.cts",
        "default": "./dist/tanstack.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "nestjs",
    "notifications",
    "sdk",
    "client",
    "tanstack-query",
    "sse"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  }
}
