{
  "name": "@dudousxd/nestjs-notifications-resilience",
  "version": "0.1.0",
  "description": "Resilient provider failover for nestjs-notifications — per-provider circuit breaker + per-attempt timeout + ordered failover, powered by @dudousxd/nestjs-resilience",
  "license": "MIT",
  "author": "Davide Carvalho",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-resilience": ">=0.1.0 <1.0.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0"
  },
  "devDependencies": {
    "@dudousxd/nestjs-resilience": "^0.2.0",
    "@nestjs/common": "^11.0.0"
  }
}
