{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // tsup/esbuild bundles the package, so resolve like a bundler: this lets the source keep
    // extensionless relative imports (`./decorators`) while still producing correct bundled
    // declarations. The published `exports` map still serves NodeNext consumers ESM + CJS .d.ts.
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts", "dist", "node_modules"]
}
