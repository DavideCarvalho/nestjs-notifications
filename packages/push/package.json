{
  "name": "@dudousxd/nestjs-notifications-push",
  "version": "0.5.1",
  "description": "Push channel for nestjs-notifications — deliver push notifications via Web Push (VAPID), Firebase Cloud Messaging, or Expo",
  "license": "MIT",
  "author": "Davide Carvalho",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/nestjs-notifications.git",
    "directory": "packages/push"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-notifications-core": ">=0.1.0 <1.0.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "web-push": "^3.6.0",
    "firebase-admin": "^12.0.0 || ^13.0.0",
    "expo-server-sdk": "^3.10.0",
    "@parse/node-apn": ">=6"
  },
  "peerDependenciesMeta": {
    "web-push": {
      "optional": true
    },
    "firebase-admin": {
      "optional": true
    },
    "expo-server-sdk": {
      "optional": true
    },
    "@parse/node-apn": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dudousxd/nestjs-notifications-core": "workspace:^",
    "@nestjs/common": "11.1.26",
    "web-push": "3.6.7",
    "firebase-admin": "13.10.0",
    "expo-server-sdk": "3.15.0",
    "@parse/node-apn": "8.1.0",
    "reflect-metadata": "0.2.2",
    "typescript": "5.9.3",
    "@types/web-push": "3.6.4"
  },
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  }
}
