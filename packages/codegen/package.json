{
  "name": "@dudousxd/nestjs-notifications-codegen",
  "version": "0.4.0",
  "description": "nestjs-codegen extension for @dudousxd/nestjs-notifications — emits the inbox + preference-center API into your generated client",
  "license": "MIT",
  "author": "Davide Carvalho",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/nestjs-notifications.git",
    "directory": "packages/codegen"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "nestjs",
    "notifications",
    "nestjs-codegen",
    "codegen",
    "inertia",
    "tanstack-query"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-codegen": ">=0.2.0"
  },
  "devDependencies": {
    "@dudousxd/nestjs-codegen": "0.3.0",
    "typescript": "5.9.3"
  },
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  }
}
