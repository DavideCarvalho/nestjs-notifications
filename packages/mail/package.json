    "@aws-sdk/client-sesv2": ">=3"
  },
  "peerDependenciesMeta": {
    "marked": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "@react-email/render": {
      "optional": true
    },
    "mjml": {
      "optional": true
    },
    "@aws-sdk/client-sesv2": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dudousxd/nestjs-notifications-core": "workspace:^",
    "@nestjs/common": "11.1.26",
    "@react-email/render": "1.4.0",
    "@types/nodemailer": "6.4.23",
    "@types/react": "18.3.31",
    "marked": "12.0.2",
    "mjml": "4.18.0",
    "nodemailer": "6.10.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@types/react-dom": "18.3.7",
