{
  "name": "@dudousxd/nestjs-notifications-event-emitter",
  "version": "0.3.0",
  "description": "In-process async dispatcher for nestjs-notifications using @nestjs/event-emitter",
  "license": "MIT",
  "author": "Davide Carvalho",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/nestjs-notifications.git",
    "directory": "packages/event-emitter"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-notifications-core": ">=0.1.0 <1.0.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/event-emitter": "^2.0.0 || ^3.0.0"
  },
  "devDependencies": {
    "@dudousxd/nestjs-notifications-core": "workspace:^",
    "@nestjs/common": "11.1.26",
    "@nestjs/core": "11.1.26",
    "@nestjs/event-emitter": "3.1.0",
    "@nestjs/testing": "11.1.26",
    "reflect-metadata": "0.2.2",
    "typescript": "5.9.3"
  },
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  }
}
